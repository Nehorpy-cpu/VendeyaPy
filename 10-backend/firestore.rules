rules_version = '2';

// ============================================================================
// VentaporWhatsapp — Reglas de seguridad de Firestore
// ----------------------------------------------------------------------------
// Modelo: Multi-tenant por documento. Cada usuario tiene custom claims
// { tenantId, role } seteados en Firebase Auth por la Cloud Function
// `userProvision`. Las reglas validan tanto el tenant como el rol.
// Ver ARCHITECTURE.md §5.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function userTenantId() {
      return request.auth.token.tenantId;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isPlatformAdmin() {
      return isSignedIn() && userRole() == 'PLATFORM_ADMIN';
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && userTenantId() == tenantId;
    }

    function isTenantOwner(tenantId) {
      return isTenantMember(tenantId) && userRole() == 'TENANT_OWNER';
    }

    function isTenantManager(tenantId) {
      return isTenantMember(tenantId)
        && userRole() in ['TENANT_OWNER', 'TENANT_MANAGER'];
    }

    function isTenantViewer(tenantId) {
      return isTenantMember(tenantId)
        && userRole() in ['TENANT_OWNER', 'TENANT_MANAGER', 'TENANT_VIEWER'];
    }

    function isTenantSeller(tenantId) {
      return isTenantMember(tenantId) && userRole() == 'SELLER';
    }

    // Staff que atiende clientes/pedidos/conversaciones (incluye al vendedor).
    function isTenantStaff(tenantId) {
      return isTenantMember(tenantId)
        && userRole() in ['TENANT_OWNER', 'TENANT_MANAGER', 'SELLER'];
    }

    // ---------- Planes (solo lectura para todos los autenticados) ----------

    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    // ---------- Métricas globales de la plataforma (solo Super Admin) ----------

    match /platformStats/{doc} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Solo Admin SDK (job)
    }

    // ---------- Globales de Meta (D2): bandeja de webhooks + índice externo ----------
    // Las escribe SOLO Cloud Functions (Admin SDK). Lectura: solo Super Admin (debug).

    match /metaWebhookInbox/{eventId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    match /metaExternalIndex/{id} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    // ---------- Idempotencia de webhooks de pago (Fase 3): solo Cloud Functions ----------
    // Marca cada evento de Stripe procesado una sola vez. Lectura: solo Super Admin (debug).
    match /stripeWebhookEvents/{eventId} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Admin SDK
    }

    // ---------- Secretos cifrados (Fase 3): NADIE los lee desde el cliente ----------
    // Tokens por referencia (Meta/pasarelas), cifrados con AES-GCM. Solo Admin SDK.
    match /secrets/{name} {
      allow read, write: if false;
    }

    // ---------- Usuarios admin ----------

    match /users/{userId} {
      // Un usuario puede leer su propio perfil
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Platform admin puede leer/escribir todos
      allow read, write: if isPlatformAdmin();
      // Solo Cloud Functions con Admin SDK pueden crear/modificar usuarios
      // (el cliente NO puede escribir directamente)
      allow write: if false;
    }

    // ---------- Tenants ----------

    match /tenants/{tenantId} {
      // Lectura: cualquier miembro del tenant (incluye vendedor) + platform admin
      allow read: if isTenantViewer(tenantId) || isTenantSeller(tenantId) || isPlatformAdmin();

      // Escritura del documento raíz del tenant: solo el owner y platform admin
      // (cambios sensibles como branding, fiscal, payments)
      allow update: if isTenantOwner(tenantId) || isPlatformAdmin();

      // Creación y borrado: solo platform admin (vía Cloud Functions con Admin SDK)
      allow create, delete: if false;

      // ---------- Subcolecciones del tenant ----------

      // Productos (el vendedor necesita verlos para atender; editar solo manager+)
      match /products/{productId} {
        allow read: if isTenantViewer(tenantId) || isTenantSeller(tenantId) || isPlatformAdmin();
        allow write: if isTenantManager(tenantId) || isPlatformAdmin();
      }

      // Costos privados de productos: el vendedor NO puede leerlos (ADR-0008).
      match /productFinancials/{productId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if isTenantManager(tenantId) || isPlatformAdmin();
      }

      // Categorías
      match /categories/{categoryId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if isTenantManager(tenantId) || isPlatformAdmin();
      }

      // Configuración del agente / checkout (editable desde el panel por el Owner)
      match /config/{doc} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if isTenantOwner(tenantId) || isPlatformAdmin();
      }

      // Clientes (el vendedor puede ver/atender; escritura de datos: manager+)
      match /customers/{customerId} {
        allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if isTenantManager(tenantId) || isPlatformAdmin();

        // Sesiones de conversación (solo Cloud Functions las escriben)
        match /sessions/{sessionId} {
          allow read: if isTenantStaff(tenantId) || isPlatformAdmin();
          allow write: if false; // Solo Admin SDK
        }

        // Historial de mensajes del chat (solo Cloud Functions lo escriben)
        match /messages/{messageId} {
          allow read: if isTenantStaff(tenantId) || isPlatformAdmin();
          allow write: if false; // Solo Admin SDK
        }
      }

      // Órdenes (el vendedor las ve y puede cambiar estado/notas)
      match /orders/{orderId} {
        allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
        // Cambios de estado críticos solo vía Cloud Functions (Admin SDK)
        allow create, delete: if false;
        // Update limitado: staff puede cambiar estado o agregar notas
        allow update: if (isTenantStaff(tenantId) || isPlatformAdmin())
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'notes', 'updatedAt']);

        match /items/{itemId} {
          allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
          allow write: if false; // Solo Admin SDK
        }
      }

      // Finanzas privadas de pedidos (costo/ganancia): el vendedor NO las lee (ADR-0008).
      match /orderFinancials/{orderId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false; // Solo Admin SDK (Cloud Functions)
      }

      // Agregados de dashboard (P7): "public" lo ve el vendedor; "private" solo manager+.
      match /stats/{doc} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin()
          || (doc == 'public' && isTenantStaff(tenantId));
        allow write: if false; // Solo Admin SDK (trigger/job)
      }

      // Snapshots diarios (incluyen ganancia → privados).
      match /statsDaily/{date} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Promociones (P8): las ve el staff (para informar al cliente); las edita el manager+.
      match /promotions/{promotionId} {
        allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if isTenantManager(tenantId) || isPlatformAdmin();
      }

      // Recomendaciones del sistema (P8+): las genera Cloud Functions. El manager+ las lee
      // y puede aceptar/descartar (solo cambia status/resolvedAt). El vendedor NO las ve.
      match /insights/{insightId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow create, delete: if false; // Solo Admin SDK (jobs)
        allow update: if (isTenantManager(tenantId) || isPlatformAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']);
      }

      // Tareas de seguimiento (P14): el staff (incl. vendedor) las lee y cambia su estado.
      // Las genera Cloud Functions; nadie las crea/borra desde el cliente.
      match /followUpTasks/{taskId} {
        allow read: if isTenantStaff(tenantId) || isPlatformAdmin();
        allow create, delete: if false; // Solo Admin SDK (jobs)
        allow update: if (isTenantStaff(tenantId) || isPlatformAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completedAt']);
      }

      // Auditoría del agente (P16): manager+ la lee y resuelve/descarta. El vendedor NO.
      match /agentAudits/{auditId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow create, delete: if false; // Solo Admin SDK (jobs)
        allow update: if (isTenantManager(tenantId) || isPlatformAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']);
      }

      // Simulador del agente (P17): casos de prueba que crea/edita/corre el manager+.
      match /agentTestCases/{testId} {
        allow read, write: if isTenantManager(tenantId) || isPlatformAdmin();
      }

      // Respuestas ganadoras (P18): el staff las lee/copia; el manager+ las cura.
      // Las "auto" las escribe el minero (Admin SDK).
      match /winningReplies/{replyId} {
        allow read: if isTenantStaff(tenantId) || isPlatformAdmin();
        allow write: if isTenantManager(tenantId) || isPlatformAdmin();
      }

      // Integración Meta (D1): conexión + activos. El manager+ los lee; los escribe
      // SOLO Cloud Functions (Admin SDK). El token nunca está acá (solo tokenSecretRef).
      match /metaConnections/{connectionId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }
      match /metaAssets/{assetId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Meta Ads (D3): campañas/adsets/ads + snapshots diarios. Datos sensibles (gasto):
      // los lee el manager+, los escribe SOLO la sync (Admin SDK).
      match /metaCampaigns/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }
      match /metaAdsets/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }
      match /metaAds/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }
      match /metaAdInsightsDaily/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }

      // Logs de sincronización del catálogo a Meta (D4): manager+ lee; escribe la sync.
      match /metaCatalogSyncLogs/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }

      // Eventos del negocio + Conversions API (D6): manager+ lee; escribe Cloud Functions.
      match /businessEvents/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }
      match /metaConversionEvents/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }

      // Tracking propio (P11): el staff ve los códigos (para informar); el manager+ los gestiona.
      match /trackingSources/{id} {
        allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if isTenantManager(tenantId) || isPlatformAdmin();
      }

      // Entregas
      match /deliveries/{deliveryId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false; // Solo Admin SDK (vía Cloud Functions)

        match /events/{eventId} {
          allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
          allow write: if false;
        }
      }

      // Repartidores
      match /deliveryPersons/{driverId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow create, update, delete: if isTenantManager(tenantId) || isPlatformAdmin();
      }

      // Pagos (solo lectura, escritura por Cloud Functions)
      match /payments/{paymentId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Facturas (solo lectura, escritura por Cloud Functions)
      match /invoices/{invoiceId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Suscripciones de clientes finales
      match /subscriptions/{subscriptionId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Webhook events (solo Cloud Functions, lectura para debug)
      match /webhookEvents/{eventId} {
        allow read: if isPlatformAdmin();
        allow write: if false;
      }
    }

    // ---------- Default deny ----------
    // Cualquier ruta no listada arriba está denegada por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
