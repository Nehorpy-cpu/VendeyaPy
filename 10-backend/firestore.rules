rules_version = '2';

// ============================================================================
// VentaporWhatsapp — Reglas de seguridad de Firestore
// ----------------------------------------------------------------------------
// Modelo: Multi-tenant por documento. Cada usuario tiene custom claims
// { tenantId, role } seteados en Firebase Auth por la Cloud Function
// `userProvision`. Las reglas validan tanto el tenant como el rol.
// Ver ARCHITECTURE.md §5.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function userTenantId() {
      return request.auth.token.tenantId;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isPlatformAdmin() {
      return isSignedIn() && userRole() == 'PLATFORM_ADMIN';
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && userTenantId() == tenantId;
    }

    function isTenantOwner(tenantId) {
      return isTenantMember(tenantId) && userRole() == 'TENANT_OWNER';
    }

    function isTenantManager(tenantId) {
      return isTenantMember(tenantId)
        && userRole() in ['TENANT_OWNER', 'TENANT_MANAGER'];
    }

    function isTenantViewer(tenantId) {
      return isTenantMember(tenantId)
        && userRole() in ['TENANT_OWNER', 'TENANT_MANAGER', 'TENANT_VIEWER'];
    }

    function isTenantSeller(tenantId) {
      return isTenantMember(tenantId) && userRole() == 'SELLER';
    }

    // Staff que atiende clientes/pedidos/conversaciones (incluye al vendedor).
    function isTenantStaff(tenantId) {
      return isTenantMember(tenantId)
        && userRole() in ['TENANT_OWNER', 'TENANT_MANAGER', 'SELLER'];
    }

    // ---------- Planes (solo lectura para todos los autenticados) ----------

    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    // ---------- Métricas globales de la plataforma (solo Super Admin) ----------

    match /platformStats/{doc} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Solo Admin SDK (job)
    }

    // ---------- Globales de Meta (D2): bandeja de webhooks + índice externo ----------
    // Las escribe SOLO Cloud Functions (Admin SDK). Lectura: solo Super Admin (debug).

    match /metaWebhookInbox/{eventId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    match /metaExternalIndex/{id} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    // ---------- Idempotencia de webhooks de pago (Fase 3): solo Cloud Functions ----------
    // Marca cada evento de Stripe procesado una sola vez. Lectura: solo Super Admin (debug).
    match /stripeWebhookEvents/{eventId} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Admin SDK
    }

    // ---------- Secretos cifrados (Fase 3): NADIE los lee desde el cliente ----------
    // Tokens por referencia (Meta/pasarelas), cifrados con AES-GCM. Solo Admin SDK.
    match /secrets/{name} {
      allow read, write: if false;
    }

    // ---------- Nonces del OAuth de Meta (Fase 4B): solo Cloud Functions (Admin SDK) ----------
    // Estado de un solo uso del Embedded Signup (atado a tenant+uid, TTL corto). Nadie lo
    // lee/escribe desde el cliente.
    match /metaOAuthStates/{id} {
      allow read, write: if false;
    }

    // ---------- Idempotencia de billing de plataforma (Fase 4): solo Cloud Functions ----------
    match /platformBillingEvents/{eventId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    // ---------- Usuarios admin ----------

    match /users/{userId} {
      // Un usuario puede leer su propio perfil
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Platform admin puede leer/escribir todos
      allow read, write: if isPlatformAdmin();
      // Solo Cloud Functions con Admin SDK pueden crear/modificar usuarios
      // (el cliente NO puede escribir directamente)
      allow write: if false;
    }

    // ---------- Tenants ----------

    match /tenants/{tenantId} {
      // Lectura: cualquier miembro del tenant (incluye vendedor) + platform admin
      allow read: if isTenantViewer(tenantId) || isTenantSeller(tenantId) || isPlatformAdmin();

      // Escritura del documento raíz del tenant: solo el owner y platform admin pueden
      // editar campos NO sensibles (branding, fiscal, payments, contacto...). Los campos de
      // entitlements/billing (plan, límites, uso, suscripción, estado, demo) y el estado de
      // onboarding NO son editables desde el cliente — solo Cloud Functions (Admin SDK):
      // onboarding.completed lo marca el callable completeOnboarding (R-1/R-2). El frontend
      // nunca decide seguridad.
      // `trial` (TRIAL-ENFORCEMENT-1A) y `featureOverrides` (PLAN-LIMITS-3B) son server-set: solo Admin SDK
      // los escribe (provisionTenantCore / activación). El cliente —owner o admin— NO puede editarlos.
      allow update: if (isTenantOwner(tenantId) || isPlatformAdmin())
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['planId', 'limits', 'limitOverrides', 'featureOverrides', 'usage', 'subscription', 'status', 'isDemo', 'trial', 'deletedAt', 'onboarding']);

      // Creación y borrado: solo platform admin (vía Cloud Functions con Admin SDK)
      allow create, delete: if false;

      // ---------- Subcolecciones del tenant ----------

      // Productos (el vendedor necesita verlos para atender). La ESCRITURA pasa solo por
      // callable (productUpsert/productDelete, Admin SDK) — Fase 5C cierre 2.
      match /products/{productId} {
        allow read: if isTenantViewer(tenantId) || isTenantSeller(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Costos privados de productos: el vendedor NO puede leerlos (ADR-0008). La ESCRITURA
      // pasa solo por callable (productUpsert/productDelete, Admin SDK) — Fase 5C cierre 1.
      match /productFinancials/{productId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Categorías. La ESCRITURA pasa solo por callable (categoryUpsert/categoryDelete,
      // Admin SDK) — Fase 5C cierre 3. categoryDelete bloquea si hay productos asociados.
      match /categories/{categoryId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Configuración del agente / checkout / canales. La ESCRITURA pasa solo por callables
      // (agentConfigUpdate / checkoutConfigUpdate / channelConfigUpdate, Admin SDK) — Fase 5C cierre
      // G-1. El wildcard {doc} cubre agent/checkout/channels y cualquier config doc futuro.
      // Lectura: viewer+ del tenant o platform admin (sin cambios).
      match /config/{doc} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Clientes (el vendedor puede ver/atender; escritura de datos: manager+)
      match /customers/{customerId} {
        allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if isTenantManager(tenantId) || isPlatformAdmin();

        // Sesiones de conversación (solo Cloud Functions las escriben)
        match /sessions/{sessionId} {
          allow read: if isTenantStaff(tenantId) || isPlatformAdmin();
          allow write: if false; // Solo Admin SDK
        }

        // Historial de mensajes del chat (solo Cloud Functions lo escriben)
        match /messages/{messageId} {
          allow read: if isTenantStaff(tenantId) || isPlatformAdmin();
          allow write: if false; // Solo Admin SDK
        }
      }

      // Órdenes: SOLO lectura desde el cliente (ORDER-1). Toda mutación va por callables
      // auditados (orderUpdate / orderCancel / orderUpdateStatus / adminOrderCorrect), que
      // hacen cumplir la máquina de estados (orders/lifecycle.ts): editar/cancelar solo
      // antes del pago, avance forward, correcciones solo PLATFORM_ADMIN. Nunca hard-delete.
      // (Antes: update directo de status/notes para staff SIN validar transiciones — un
      // seller podía marcar PAID sin pago. Cerrado.)
      match /orders/{orderId} {
        allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
        allow create, update, delete: if false;

        match /items/{itemId} {
          allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
          allow write: if false; // Solo Admin SDK
        }
      }

      // Finanzas privadas de pedidos (costo/ganancia): el vendedor NO las lee (ADR-0008).
      match /orderFinancials/{orderId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false; // Solo Admin SDK (Cloud Functions)
      }

      // Agregados de dashboard (P7): "public" lo ve el vendedor; "private" solo manager+.
      match /stats/{doc} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin()
          || (doc == 'public' && isTenantStaff(tenantId));
        allow write: if false; // Solo Admin SDK (trigger/job)
      }

      // Snapshots diarios (incluyen ganancia → privados).
      match /statsDaily/{date} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Promociones (P8): las ve el staff (para informar al cliente). La ESCRITURA pasa solo por
      // callable (promotionUpsert/promotionDelete, Admin SDK) — Fase 5C cierre growth G-2.
      // promotionDelete es SOFT (status='FINISHED'); el panel oculta las finalizadas.
      match /promotions/{promotionId} {
        allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Recomendaciones del sistema (P8+): las genera Cloud Functions. El manager+ las lee
      // y puede aceptar/descartar (solo cambia status/resolvedAt). El vendedor NO las ve.
      match /insights/{insightId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow create, delete: if false; // Solo Admin SDK (jobs)
        allow update: if (isTenantManager(tenantId) || isPlatformAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']);
      }

      // Tareas de seguimiento (P14): el staff (incl. vendedor) las lee y cambia su estado.
      // Las genera Cloud Functions; nadie las crea/borra desde el cliente.
      match /followUpTasks/{taskId} {
        allow read: if isTenantStaff(tenantId) || isPlatformAdmin();
        allow create, delete: if false; // Solo Admin SDK (jobs)
        allow update: if (isTenantStaff(tenantId) || isPlatformAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completedAt']);
      }

      // Auditoría del agente (P16): manager+ la lee y resuelve/descarta. El vendedor NO.
      match /agentAudits/{auditId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow create, delete: if false; // Solo Admin SDK (jobs)
        allow update: if (isTenantManager(tenantId) || isPlatformAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']);
      }

      // Notificaciones internas del panel. Trial/billing → solo OWNER + admin (sin cambios).
      // COVERAGE-1C: la categoría 'handoff' también la lee el MANAGER, y el SELLER únicamente
      // los avisos dirigidos a su uid (targetUid, server-controlled). Nada más se amplía.
      match /notifications/{notificationId} {
        allow read: if isTenantOwner(tenantId) || isPlatformAdmin()
          || (isTenantManager(tenantId) && resource.data.category == 'handoff')
          || (isTenantSeller(tenantId) && resource.data.category == 'handoff'
              && resource.data.targetUid == request.auth.uid);
        allow create, delete: if false; // Solo Admin SDK (generateTrialNotifications / handoff)
        // El MANAGER no marca leídos los avisos DIRIGIDOS a un seller (el doc-id es determinístico:
        // si otro lo lee, el aviso muere para el vendedor asignado). El owner conserva el control.
        allow update: if (isTenantOwner(tenantId) || isPlatformAdmin()
            || (isTenantManager(tenantId) && resource.data.category == 'handoff'
                && !('targetUid' in resource.data))
            || (isTenantSeller(tenantId) && resource.data.category == 'handoff'
                && resource.data.targetUid == request.auth.uid))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      }

      // COVERAGE-1C: solicitudes de cobertura. Contienen la UBICACIÓN del cliente (sensible):
      // owner/manager del tenant y soporte de plataforma leen; el SELLER solo las asignadas a
      // su uid (sellerUid, server-controlled). Escritura SIEMPRE por callables/Admin SDK.
      match /coverageRequests/{requestId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin()
          || (isTenantSeller(tenantId) && resource.data.sellerUid == request.auth.uid);
        allow write: if false; // Solo Admin SDK (coverageApprove/Reject/RequestInfo + motor)
      }

      // COVERAGE-1C: outbox de reanudación del checkout (lo consume 1D). SOLO backend.
      match /coverageResumeJobs/{jobId} {
        allow read, write: if false;
      }

      // Uso/costo de IA (AG-3): registro por request del gateway de Claude (modelo, tokens, costo,
      // contexto, status) SIN prompts ni PII. Contiene costos → lectura manager+ (el vendedor NO).
      // Lo escribe SOLO Cloud Functions (Admin SDK); nada es escribible desde el cliente.
      match /aiRequests/{requestId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false; // Solo Admin SDK (gateway de IA)
      }

      // Simulador del agente (P17): casos de prueba que crea/edita/corre el manager+. La ESCRITURA y
      // el run pasan solo por callable (agentTestCaseUpsert/Delete/Run, Admin SDK) — Fase 5C cierre G-5.
      // lastResult/lastRunAt los escribe SOLO agentTestCaseRun (server-set).
      match /agentTestCases/{testId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Respuestas ganadoras (P18): el staff las lee/copia. La ESCRITURA pasa solo por callable
      // (winningReplyUpsert/winningReplyDelete, Admin SDK) — Fase 5C cierre growth G-4. Las "auto" las
      // mina el job (Admin SDK); winningReplyDelete es SOFT (status='ARCHIVED').
      match /winningReplies/{replyId} {
        allow read: if isTenantStaff(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Integración Meta (D1): conexión + activos. El manager+ los lee; los escribe
      // SOLO Cloud Functions (Admin SDK). El token nunca está acá (solo tokenSecretRef).
      match /metaConnections/{connectionId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }
      match /metaAssets/{assetId} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Meta Ads (D3): campañas/adsets/ads + snapshots diarios. Datos sensibles (gasto):
      // los lee el manager+, los escribe SOLO la sync (Admin SDK).
      match /metaCampaigns/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }
      match /metaAdsets/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }
      match /metaAds/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }
      match /metaAdInsightsDaily/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }

      // Logs de sincronización del catálogo a Meta (D4): manager+ lee; escribe la sync.
      match /metaCatalogSyncLogs/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }

      // Eventos del negocio + Conversions API (D6): manager+ lee; escribe Cloud Functions.
      match /businessEvents/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }
      match /metaConversionEvents/{id} { allow read: if isTenantManager(tenantId) || isPlatformAdmin(); allow write: if false; }

      // Tracking propio (P11): el staff ve los códigos (para informar). La ESCRITURA pasa solo por
      // callable (trackingSourceUpsert/trackingSourceDelete, Admin SDK) — Fase 5C cierre growth G-3.
      // El backend normaliza el `code`; trackingSourceDelete es SOFT (active=false).
      match /trackingSources/{id} {
        allow read: if isTenantStaff(tenantId) || isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Bitácora de auditoría (Fase 5): la leen manager+; la escribe SOLO Cloud Functions.
      match /auditLogs/{id} {
        allow read: if isTenantManager(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Entregas
      match /deliveries/{deliveryId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false; // Solo Admin SDK (vía Cloud Functions)

        match /events/{eventId} {
          allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
          allow write: if false;
        }
      }

      // Repartidores. La ESCRITURA pasa solo por callable (deliveryPersonUpsert/
      // deliveryPersonDelete, Admin SDK) — Fase 5C cierre growth G-0. El panel no escribe
      // deliveryPersons directo (CRUD 100% por callable). deliveryPersonDelete es SOFT.
      match /deliveryPersons/{driverId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Pagos (solo lectura, escritura por Cloud Functions)
      match /payments/{paymentId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Facturas (solo lectura, escritura por Cloud Functions)
      match /invoices/{invoiceId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Suscripciones de clientes finales
      match /subscriptions/{subscriptionId} {
        allow read: if isTenantViewer(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Solicitudes de activación manual de plan (billing manual por WhatsApp, MB). El owner ve las
      // SUYAS; el admin las gestiona. Escritura SOLO por callable (Admin SDK) — el owner no se autoaprueba.
      match /manualActivationRequests/{requestId} {
        allow read: if isTenantOwner(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Solicitudes de activación asistida de WhatsApp (WM-2). El owner ve las SUYAS; el admin las
      // gestiona/completa. Escritura SOLO por callable (Admin SDK) — el owner no se autoconecta.
      match /whatsappActivationRequests/{requestId} {
        allow read: if isTenantOwner(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      // Webhook events (solo Cloud Functions, lectura para debug)
      match /webhookEvents/{eventId} {
        allow read: if isPlatformAdmin();
        allow write: if false;
      }
    }

    // Bandeja del Super Admin: solicitudes de activación manual de TODOS los tenants (collectionGroup).
    // La lectura por-tenant del owner ya la cubre el match anidado tenants/{t}/manualActivationRequests.
    match /{path=**}/manualActivationRequests/{requestId} {
      allow read: if isPlatformAdmin();
    }

    // Bandeja del Super Admin: solicitudes de activación de WhatsApp de TODOS los tenants (collectionGroup).
    // La lectura por-tenant del owner ya la cubre el match anidado tenants/{t}/whatsappActivationRequests.
    match /{path=**}/whatsappActivationRequests/{requestId} {
      allow read: if isPlatformAdmin();
    }

    // ---------- Default deny ----------
    // Cualquier ruta no listada arriba está denegada por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
