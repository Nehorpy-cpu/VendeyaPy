# ============================================================================
# apps/web — Variables de entorno de PRODUCCIÓN (PLANTILLA — SIN valores reales)
# ----------------------------------------------------------------------------
# Copiá este archivo a `apps/web/.env.production` (o seteá estas vars en el
# entorno del BUILD de deploy) y completá los valores de vpw-prod.
#
# BUILD-TIME: Next.js "hornea" las `NEXT_PUBLIC_*` en el bundle del cliente
# durante `next build`. Si faltan en el momento del build, quedan VACÍAS en
# producción (Firebase mal apuntado, Meta sin activar, soporte sin link).
#
# PÚBLICO vs SECRETO: TODAS las `NEXT_PUBLIC_*` son PÚBLICAS (viajan al browser).
# NINGUNA es secreta. La API key de Firebase Web es un identificador de proyecto,
# NO una credencial (la seguridad real la dan Firestore/Storage rules + Auth).
# Los secretos de backend (App Secret, clave de encriptación, tokens, API keys
# de IA) NO van acá: van al runtime de Functions / Secret Manager
# (ver docs/deploy-readiness.md §5.2).
#
# NUNCA commitees `apps/web/.env.production` con valores reales (gitignored).
# Este `.example` NO lleva valores: es solo la lista de claves.
# ============================================================================

# ===== Firebase Web (proyecto vpw-prod) — PÚBLICO =====
# Firebase Console → vpw-prod → Project Settings → Your apps → SDK setup config.
# Pegá los valores EXACTOS que muestra la consola (no inventar).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=vpw-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=vpw-prod
# Usá el bucket EXACTO de la consola (proyectos nuevos pueden mostrar
# `vpw-prod.firebasestorage.app` en vez de `vpw-prod.appspot.com`).
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=vpw-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ===== Emuladores — OBLIGATORIO en prod =====
# DEBE ser `false` (o ausente) en producción. Si queda `true`, el panel de prod
# habla con localhost (todo roto) y expone datos/acciones DEMO. ★ RIESGO #1 ★
NEXT_PUBLIC_USE_EMULATORS=false

# ===== Meta Embedded Signup (conexión REAL de WhatsApp) — PÚBLICO =====
# App ID + config_id del Embedded Signup para el flujo REAL de conexión de Meta.
# Si falta alguno, Integraciones queda en estado honesto "Meta no configurada"
# y NO intenta el OAuth real (INTEGRATIONS-PROD-SAFETY).
# El App SECRET vive SOLO en el backend (META_APP_SECRET, Secret Manager) — acá NO.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
NEXT_PUBLIC_META_GRAPH_VERSION=v19.0

# ===== Soporte — PÚBLICO =====
# Número de WhatsApp de soporte (solo dígitos con código de país, ej. 549XXXXXXXXXX).
# Arma el link wa.me para la activación manual de planes y el RegistrationGate.
# Si falta, esos botones de "contactar soporte" no se muestran.
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# ===== SINGLE-TENANT-LOCK — PÚBLICO =====
# En "false", /register muestra "registro por invitación" (con el wa.me de soporte) y el login
# oculta el CTA de alta. Es solo UI: la barrera REAL es ALLOW_SELF_REGISTRATION=false en el env
# de functions (registerTenantOwner rechaza con failed-precondition). Ausente = registro abierto.
NEXT_PUBLIC_ALLOW_SELF_REGISTRATION=

# ===== API base (Cloud Functions) — PÚBLICO · OPCIONAL en prod =====
# Solo la usan endpoints de DEV-TOOLING (devSync*, devGenerate*, devCompute*,
# devMessage, devProcessConversions…), que devuelven 404 en producción
# (guardDevEndpoint). Las rutas REALES del panel usan el SDK de Firestore +
# callables autenticados, NO esto. Seteala a la base real de functions de
# vpw-prod para evitar el fallback a localhost; igual esos endpoints no operan
# en prod.
NEXT_PUBLIC_API_BASE_URL=https://us-central1-vpw-prod.cloudfunctions.net
