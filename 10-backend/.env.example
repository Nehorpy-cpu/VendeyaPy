# ============================================================================
# VentaporWhatsapp — Variables de entorno
# ----------------------------------------------------------------------------
# Copia este archivo a .env.local y completa los valores.
# NUNCA commitees .env.local ni ningún archivo con valores reales.
# Los secretos por tenant se guardan cifrados en Firestore (NO en este archivo).
# ============================================================================

# ===== FIREBASE =====
# Obtener en: https://console.firebase.google.com → Project Settings
FIREBASE_PROJECT_ID=vpw-dev
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=vpw-dev.firebaseapp.com
FIREBASE_STORAGE_BUCKET=vpw-dev.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Service Account para Admin SDK (solo en server/CI)
# Ruta a JSON descargado desde Firebase Console
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# ===== EMULADORES (solo desarrollo local) =====
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
PUBSUB_EMULATOR_HOST=localhost:8085

# ===== N8N =====
N8N_BASE_URL=https://n8n.ventaporwhatsapp.com
N8N_INTERNAL_SECRET=cambiar-en-cada-entorno-min-32-chars

# ===== API =====
API_BASE_URL=http://localhost:5001
WEB_BASE_URL=http://localhost:3000

# ===== ENCRIPTACIÓN DE SECRETOS DE TENANT =====
# Clave maestra para cifrar credenciales por tenant en Firestore.
# Mínimo 32 caracteres. Rotar requiere migración de datos.
TENANT_SECRETS_ENCRYPTION_KEY=

# ===== WHATSAPP CLOUD API (Meta) =====
# Token de verificación del webhook (configurado en Meta Business Platform)
# NOTA: Las credenciales por tenant (access_token, phone_number_id) se almacenan
# en Firestore bajo /tenants/{id}/whatsapp, cifradas.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=cambiar-en-cada-entorno
WHATSAPP_APP_SECRET=

# ===== STRIPE (plataforma) =====
# Solo para cobro de suscripciones del SaaS (no para tenants).
# Los tenants tienen sus propias keys de Stripe en su config.
PLATFORM_STRIPE_SECRET_KEY=
PLATFORM_STRIPE_WEBHOOK_SECRET=

# ===== ENDPOINTS DEV (Fase 2) =====
# En PRODUCCIÓN no setear ENABLE_DEV_ENDPOINTS (los dev* quedan en 404).
ENABLE_DEV_ENDPOINTS=
DEV_ENDPOINTS_SECRET=

# ===== WHATSAPP CLOUD API — envío de respuestas =====
# DEPRECATED (Fase 4A): el envío real es POR TENANT (config/channels.whatsappSendMode='live'
# + conexión Meta del tenant + token vía SecretStore). Estas globales NO se usan en producción
# normal; solo como bootstrap mono-tenant si ALLOW_GLOBAL_WHATSAPP_FALLBACK=true.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Habilita el fallback global deprecado de arriba (default false → no enviar con globales).
ALLOW_GLOBAL_WHATSAPP_FALLBACK=false

# ===== STRIPE — pagos del cliente + billing del SaaS (Fase 3/4) =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_BILLING_WEBHOOK_SECRET=
# Mapeo Price ID → planId (Fase 5B-i). JSON: el plan efectivo sale del precio confirmado por
# Stripe en el webhook (el frontend nunca decide el plan). Ej: {"price_xxx":"starter","price_yyy":"growth"}
STRIPE_PRICE_TO_PLAN=

# ===== PAYPAL — billing de la suscripción del SaaS (Fase 5B-ii) =====
# Credenciales de la cuenta PayPal Business de la PLATAFORMA (el dinero llega acá, no al tenant).
# El client secret NUNCA va a Firestore ni a logs.
PAYPAL_ENV=sandbox            # sandbox | live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=            # id del webhook (para verificar la firma con el método oficial)
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=
# Mapeos de plan (el plan efectivo sale de lo confirmado por PayPal en el webhook):
# PAYPAL_PLAN_TO_PLAN: { "<paypalPlanId>": "<planId>" }   (webhook)
# PLAN_TO_PAYPAL_PLAN: { "<planId>": "<paypalPlanId>" }   (createPayPalSubscriptionSession)
PAYPAL_PLAN_TO_PLAN=
PLAN_TO_PAYPAL_PLAN=

# ===== META OAUTH — Embedded Signup (Fase 3) =====
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=

# ===== CLAUDE / ANTHROPIC (AI Gateway · AG-1) =====
# Secreto SOLO de backend. Sin esta key en prod, el AI Gateway queda 'disabled' y el bot usa el
# motor rule-based (fallback). En emulador/tests NO se usa: se inyecta un cliente fake (cero red).
ANTHROPIC_API_KEY=

# ===== LOGGING =====
LOG_LEVEL=info
NODE_ENV=development
